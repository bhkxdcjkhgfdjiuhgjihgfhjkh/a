--functions

function bindKey(txtgui, callback)
	txtgui.Text = "Press any key"
	local connection
	connection = UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
		if input.UserInputType == Enum.UserInputType.Keyboard then
			if input.KeyCode ~= Enum.KeyCode.Escape then
				local output = input.KeyCode
				txtgui.Text = string.upper(output.Name)
				if connection then
					connection:Disconnect()
				end
				if callback then
					callback(output)
				end
			end
		end
	end)
end

function decode(inputString)
	if inputString=="" or inputString==nil then return nil else
		local parts = {}
		for part in string.gmatch(inputString, "([^;]+)") do
			table.insert(parts, part)
		end
		return parts[1]
	end
end

function fDash()
	local hrp = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local h = game.Players.LocalPlayer.Character:FindFirstChild("Humanoid")
	if hrp and h then
		local target=game.Players.LocalPlayer.Character:GetAttribute("LastM1Hitted")
		fd=true
		local fp = Instance.new("Part",workspace)
		fp.Anchored=true
		fp.CanCollide = false
		fp.Transparency = 1
		local anim = Instance.new("Animation")
		anim.AnimationId = "rbxassetid://10480793962"

		local attach = Instance.new("Attachment",hrp)

		local LinearVelocity = Instance.new("LinearVelocity",attach)

		local part = Instance.new("Part",workspace)
		part.Anchored = true
		part.CanCollide = false
		part.Transparency = 0
		if game.Players.LocalPlayer.Character:GetAttribute("Character")=="Ninja" then
			part.CFrame = hrp.CFrame * CFrame.new(40,0,0)
			fp.CFrame = hrp.CFrame * CFrame.new(40,0,0)
		else
			part.CFrame = hrp.CFrame * CFrame.new(30,0,0)
			fp.CFrame = hrp.CFrame * CFrame.new(30,0,0)
		end
		local animplay = h:LoadAnimation(anim)
		animplay:Play()

		LinearVelocity.MaxForce = 9999999
		LinearVelocity.VectorVelocity = (part.Position-hrp.Position).Unit*Vector3.new(150,0,150)
		LinearVelocity.Attachment0 = attach
		task.wait(0.15)
		attach:Destroy()
		part:Destroy()
		LinearVelocity:Destroy()
		fd=false
		wait(.06)
		hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
		hrp.CFrame=fp.CFrame*CFrame.Angles(0,math.rad(80),0)
		fp:Destroy()
		task.wait(0.05)
		vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
		vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
		local look = decode(target)
		if look ~=nil then
			local vp1 = workspace.Live:FindFirstChild(look)
			vp1=vp1.PrimaryPart
			for i = 1, 100 do
				hrp.CFrame = CFrame.lookAt(hrp.Position,Vector3.new(vp1.Position.X,hrp.Position.Y,vp1.Position.Z))
				task.wait()
			end
		end
	end
end

function sdc(animationTrack:AnimationTrack,side:boolean)
	ad=1.5
	if game.Players.LocalPlayer.Character.Humanoid.FloorMaterial~=Enum.Material.Air then game.Players.LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
	wait(.02)
	animationTrack:Stop()
	local hrp=game.Players.LocalPlayer.Character.HumanoidRootPart
	local part = Instance.new("Part",workspace)
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 1
	if side then
		part.CFrame = hrp.CFrame * CFrame.new(40,0,0)
	else
		part.CFrame = hrp.CFrame * CFrame.new(-40,0,0)
	end
	local hy=hrp.AssemblyLinearVelocity.Y
	hrp.AssemblyLinearVelocity = (part.Position-hrp.Position).Unit*Vector3.new(dd,0,dd)
	hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X, hy, hrp.AssemblyLinearVelocity.Z)
	part:Destroy()
end 

