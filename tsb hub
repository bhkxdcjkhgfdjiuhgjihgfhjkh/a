UserInputService.InputBegan:Connect(function(input: InputObject, gameProcessedEvent: boolean) 
	if input.KeyCode == p1tobindkey and not gameProcessedEvent then
		if not p1tobinding and not p1fdbinding then
			if p1to==true then
				p1to=false
				p1tobut.BackgroundColor3=Color3.fromRGB(255,0,0)
				p1togui.BackgroundColor3=Color3.fromRGB(255,0,0)
			else
				p1to=true
				p1tobut.BackgroundColor3=Color3.fromRGB(0,255,0)
				p1togui.BackgroundColor3=Color3.fromRGB(0,255,0)
			end	
		end
	elseif input.KeyCode == p1fdbindkey and p1to and not gameProcessedEvent then
		if not p1tobinding and not p1fdbinding then
			fDash()
		end
	elseif input.KeyCode == p2tobindkey and not gameProcessedEvent then
		if not p2tobinding then
			if p2to==true then
				p2to=false
				p2tobut.BackgroundColor3=Color3.fromRGB(255,0,0)
				p2togui.BackgroundColor3=Color3.fromRGB(255,0,0)
			else
				p2to=true
				p2tobut.BackgroundColor3=Color3.fromRGB(0,255,0)
				p2togui.BackgroundColor3=Color3.fromRGB(0,255,0)
			end	
		end
	elseif input.KeyCode == p2audbindkey and p2to and not gameProcessedEvent then
		if not p2audbinding then
			if aud then
				WSdash.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				aud=false
			else
				WSdash.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
				aud=true
			end
		end
	end
end)

