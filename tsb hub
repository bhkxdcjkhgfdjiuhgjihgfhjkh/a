function lookUp(hrp:BasePart,thrp:BasePart)
	local addY=1.5
	local idk=1
	local absx = math.abs(thrp.Position.X-hrp.Position.X)
	local absz = math.abs(thrp.Position.Z-hrp.Position.Z)
	if absx>=idk or absz>=idk then
		hrp.CFrame =CFrame.lookAt(hrp.Position,Vector3.new(thrp.Position.X,hrp.Position.Y+addY,thrp.Position.Z))
	end
end

function aimbotanim(at:AnimationTrack)
	local waitmore = false
	if not p2to then return end
	local animId = at.Animation.AnimationId
	if animId == "rbxassetid://12296113986" then
		vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
		at:GetMarkerReachedSignal("finalslam"):Connect(function()
			task.wait(0.05)
			vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
			vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
			vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
		end)
	end
	if animId == "rbxassetid://95034083206292" and p2to then
		vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
		waitmore=true
		mgbd=at:GetMarkerReachedSignal("slam"):Connect(function()
			task.wait(0.05)
			game.Players.LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			for i=1,25 do 
				vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
				vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
				task.wait(0.01)
			end				
			vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			mgbd:Disconnect()
		end)
	end
	if animId == "rbxassetid://10503381238" and aud and p2to then
		ud=at:GetMarkerReachedSignal("hitreg"):Connect(function()
			task.wait()
			vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
			vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
			ud:Disconnect()
			Frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			aud=false
		end)
	end
	if animId == "rbxassetid://94638356008696" and p2to then
		vim:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
		local slam = 0
		mgcd=at:GetMarkerReachedSignal("slam"):Connect(function()
			slam+=1 if slam<3 then return end
			task.wait(0.05)
			for i=1,2 do 
				game.Players.LocalPlayer.Character.Humanoid.JumpPower=75
				game.Players.LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				task.wait()
			end
			for i=1,25 do 
				vim:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
				vim:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
				task.wait(0.01)
			end				
			mgcd:Disconnect()
			vim:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
		end)
	end
	if targetAnimations[animId] then
		local att=game.Players.LocalPlayer.Character:GetAttribute("LastM1Hitted")
		if att==nil or att=="" then return end
		local mat=decode(att)
		local target=workspace.Live:FindFirstChild(mat)
		if waitmore then
			task.wait(math.random(4,10)/10)
		end
		task.wait(tonumber(p2wait.Text))
		for i,v in pairs(target:GetDescendants()) do
			if v:IsA("Part") then
				v.CanCollide=false
			end
		end
		workspace.Gravity=100
		local hrp=game.Players.LocalPlayer.Character.HumanoidRootPart
		renderConn = game:GetService("RunService").RenderStepped:Connect(function()
			lookUp(hrp,target.HumanoidRootPart)
		end)

		stoppedConn = at.Stopped:Connect(function()
			if renderConn then
				renderConn:Disconnect()
				workspace.Gravity=192.8
			end
			target.Torso.CanCollide=true
			if ud then
				ud:Disconnect()
			end
			if gld then
				gld:Disconnect()
			end
			if mgbd then
				mgbd:Disconnect()
			end
			if mgcd then
				mgcd:Disconnect()
			end
		end)
		
	end
end

